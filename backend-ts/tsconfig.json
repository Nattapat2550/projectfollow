{
	"compilerOptions": {
		"target": "es2025",
		"lib": ["ES2025"],
		"module": "esnext",
		"moduleResolution": "bundler",
		/* Aliases */
		"paths": {
			"@/*": ["./src/*"]
		},
		"noEmit": true,
		"rootDir": "./src",
		"outDir": "./build",
		"resolveJsonModule": true,
		"allowJs": true,
		/* Strictness */
		"strict": true,
		"noUncheckedIndexedAccess": true,
		/* Base Options: */
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["node_modules", "build"]
}
