// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// กำหนด Enum สำหรับผลลัพธ์ (result) ของฝั่งส่งกลับ
enum DeportedResult {
  SUCCESS
  FAILED
  PENDING
}

// 📌 ตารางผู้ใช้งาน (สำหรับระบบ Login)
model User {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @unique @db.VarChar(50)
  password String @db.VarChar(255)
  role     String @default("user") @db.VarChar(20)
  color    String @default("#3B82F6") @db.VarChar(7)

  @@map("users") // ผูกกับชื่อตาราง users ในฐานข้อมูล
}

// ตาราง แอบเข้า (Illegal Immigrants)
model illegal_immigrants {
  id                String    @id @default(uuid())
  first_name_th     String
  middle_name_th    String?
  last_name_th      String
  first_name_en     String?
  middle_name_en    String?
  last_name_en      String?  
  passport_id       String?
  gender            String?
  nationality       String?   
  detected_date     DateTime?
  detected_location String
  is_victim         Boolean?
  warrant           String?
  workplace         String?
  screening_details String?
  photo_url         String?
}

// ตาราง ส่งกลับ (Deported Persons)
model deported_persons {
  id                 String         @id @default(uuid())
  first_name_th      String
  middle_name_th     String?
  last_name_th       String
  first_name_en      String?
  middle_name_en     String?
  last_name_en       String?
  date_of_birth      DateTime?
  age                Int?
  national_id        String         @unique
  passport_id        String?        @unique
  gender             String?
  address            String
  photo_url          String?
  
  // -- ข้อมูลที่เพิ่มใหม่ --
  building           String?
  floor              String?
  room               String?
  job_type           String?
  role               String?
  salary             String?
  paid_by            String?
  payment_method     String?
  victim_indicator   String?
  responsible_agency String?
  note               String?
  // --------------------

  number_of_case     Int            @default(0)
  number_of_warrant  Int            @default(0)
  return_date        DateTime?
  channel            String?
  result             DeportedResult @default(PENDING) 
}