// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// กำหนด Enum สำหรับผลลัพธ์ (result) ของฝั่งส่งกลับ (สามารถปรับแก้ค่าด้านในได้ตามต้องการ)
enum DeportedResult {
  SUCCESS
  FAILED
  PENDING
}

// ตาราง แอบเข้า (Illegal Immigrants)
model illegal_immigrants {
  id                String    @id @default(uuid())
  first_name_th     String
  middle_name_th    String?
  last_name_th      String
  first_name_en     String?
  middle_name_en    String?  
  last_name_en      String?  
  passport_id       String?   
  gender            String?   
  nationality       String?   
  detected_date     DateTime? 
  detected_location String
  is_victim         Boolean?
  warrant           String?   
  workplace         String?   // <--- เพิ่มฟิลด์นี้ (สถานที่ทำงาน)
}

// ตาราง ส่งกลับ (Deported Persons)
model deported_persons {
  id                String         @id @default(uuid())
  first_name_th     String
  middle_name_th    String?
  last_name_th      String
  first_name_en     String?
  middle_name_en    String?
  last_name_en      String?
  date_of_birth     String
  national_id       String         @unique
  passport_id       String?        @unique
  number_of_case    Int            @default(0)
  number_of_warrant Int            @default(0)
  address           String
  photo_url         String?        // รูปจาก ทร.14
  age               Int?           // อายุ ณ วันที่ส่งกลับ
  return_date       DateTime?      // วันที่ส่งกลับมา
  channel           String?        // ช่องทางที่ส่งกลับมา
  result            DeportedResult @default(PENDING) // กำหนดค่าเริ่มต้นเป็น PENDING ให้รองรับตอน insert
}